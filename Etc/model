    @classmethod
    def flattened_team_values(cls):
        values = []
        for parent, children in cls.TEAMS.items():
            values.append(parent)
            values.extend(children)
        return values

    @classmethod
    def flattened_office_locations(cls):
        values = []
        for location_list in cls.OFFICE_LOCATIONS.values():
            values.extend(location_list)
        return values

    @classmethod 
    def flattened_remote_locations(cls):
        values = []
        for location_list in cls.REMOTE_LOCATIONS.values():
            values.extend(location_list)
        return values

